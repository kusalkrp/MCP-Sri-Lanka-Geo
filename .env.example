# ============================================================
# mcp-srilanka-geo — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Database
# Production: use a restricted app user (see app/db/migrations/002_app_user.sql)
# Generate password: python -c "import secrets; print(secrets.token_hex(24))"
DATABASE_URL=postgresql://srilanka_app:changeme_app@postgres:5432/srilanka_geo
DB_PASSWORD=changeme_postgres_superuser

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=                    # Leave empty for local, required for Qdrant Cloud

# Redis — always set a password, even on private networks
# Generate password: python -c "import secrets; print(secrets.token_hex(24))"
REDIS_URL=redis://:changeme_redis@redis:6379
REDIS_PASSWORD=changeme_redis

# Gemini (for embeddings)
# Scope this key to embedding only — do not reuse a full-access key
GEMINI_API_KEY=your-gemini-api-key-here

# Auth
# Comma-separated list of API keys — minimum 32 characters each
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=bizmind-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,eduintel-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REQUIRE_AUTH=true                  # Set to false ONLY disables stdio auth — SSE always requires auth
# Admin key for /admin/keys endpoints (list, revoke). Must be >= 32 chars.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_KEY=

# Pipeline scheduler
PIPELINE_SCHEDULE_DAYS=7          # Run full sync every N days (default: 30)
PIPELINE_SKIP_EMBEDDINGS=false     # Set true to skip Gemini embedding step
PIPELINE_DATA_DIR=/app/data        # Where PBF + GADM files are stored
PIPELINE_PBF_URL=https://download.geofabrik.de/asia/sri-lanka-latest.osm.pbf
PIPELINE_GADM_LEVEL1_URL=https://geodata.ucdavis.edu/gadm/gadm4.1/json/gadm41_LKA_1.json
PIPELINE_GADM_LEVEL2_URL=          # Optional — leave empty to skip DS divisions
PIPELINE_GEONAMES_URL=https://download.geonames.org/export/dump/LK.zip
